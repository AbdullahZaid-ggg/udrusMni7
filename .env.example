# Idrus Men7 - Environment Variables Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env files to version control!

# Example environment variables (add as needed)
# REACT_APP_API_URL=http://localhost:3001
# REACT_APP_FIREBASE_API_KEY=your_api_key_here
# REACT_APP_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Note: Any variable starting with REACT_APP_ will be exposed to the client
# Only use for public/limited-scope keys, not database passwords or secrets